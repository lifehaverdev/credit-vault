    "devdoc": {
      "kind": "dev",
      "methods": {
        "adoptBeacon()": {
          "details": "One-time function to take ownership of the `charterBeacon` after      deployment. Must be called by the current beacon owner."
        },
        "computeCharterAddress(address,bytes32)": {
          "params": {
            "_owner": "The future owner (unused in address derivation but preserved for API compatibility).",
            "_salt": "The 32-byte salt for the CREATE2 operation."
          },
          "returns": {
            "_0": "The computed address of the new chartered fund."
          }
        },
        "contributeFor(address,address,uint256)": {
          "details": "Anyone can act as a sponsor; tokens are pulled from `msg.sender`."
        },
        "onERC721Received(address,address,uint256,bytes)": {
          "details": "Returns the selector required to accept ERC721s"
        },
        "proxiableUUID()": {
          "details": "Returns the storage slot used by the implementation, as specified in [ERC1822](https://eips.ethereum.org/EIPS/eip-1822). Note: The `notDelegated` modifier prevents accidental upgrades to an implementation that is a proxy contract."
        },
        "upgradeToAndCall(address,bytes)": {
          "details": "Upgrades the proxy's implementation to `newImplementation`. Emits a {Upgraded} event. Note: Passing in empty `data` skips the delegatecall to `newImplementation`."
        }
      },
      "version": 1
